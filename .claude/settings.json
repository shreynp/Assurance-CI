{
  "permissions": {
    "allow": [
      "Bash(python scripts/*)",
      "Bash(pytest *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ruff check*)",
      "Read",
      "Write",
      "Edit"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/format-file.sh \"${CLAUDE_TOOL_INPUT_FILE_PATH}\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'REMINDER: src/domain/ must stay pure (no I/O). All I/O in scripts/. Seed data → traceability/register.json only.'"
          }
        ]
      }
    ]
  }
}

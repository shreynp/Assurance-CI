{
  "permissions": {
    "allow": [
      "Bash(python scripts/*)",
      "Bash(pytest *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(ruff check*)",
      "Read",
      "Write",
      "Edit"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/format-file.sh \"${CLAUDE_TOOL_INPUT_FILE_PATH}\""
          }
        ]
      }
    ]
  }
}
